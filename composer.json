{
    "name": "fredbradley/annual-leave-widget",
    "description": "A Laravel package for displaying annual leave events from Google Calendar ICS feeds",
    "type": "library",
    "keywords": [
        "laravel",
        "annual-leave",
        "calendar",
        "ics",
        "google-calendar",
        "widget",
        "leave-management"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Fred Bradley",
            "email": "hello@fredbradley.co.uk"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "illuminate/view": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CranleighSchool\\AnnualLeave\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CranleighSchool\\AnnualLeave\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CranleighSchool\\AnnualLeave\\AnnualLeaveServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
